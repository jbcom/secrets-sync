{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "production": [
      "default",
      "!{projectRoot}/tests/**/*",
      "!{projectRoot}/**/*_test.go"
    ]
  },
  "targetDefaults": {
    "test": {
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "build": {
      "cache": true,
      "dependsOn": ["^build"]
    }
  },
  "defaultBase": "main"
}
